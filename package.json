{
  "name": "techno-style",
  "version": "1.0.0",
  "description": "Корпоративный сайт ТехноСтиль - поставка промышленного оборудования",
  "main": "src/main.js",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src/assets/js --ext .js --fix",
    "format": "prettier --write src/**/*.{js,css,html}",
    "clean": "rimraf dist",
    "build:prod": "npm run clean && npm run build"
  },
  "keywords": [
    "промышленное оборудование",
    "корпоративный сайт",
    "vite",
    "vanilla js"
  ],
  "author": "ТехноСтиль",
  "license": "MIT",
  "devDependencies": {
    "eslint": "^8.53.0",
    "glob": "^10.3.0",
    "prettier": "^3.0.3",
    "rimraf": "^5.0.5",
    "terser": "^5.24.0",
    "vite": "^5.1.1"
  },
  "dependencies": {
    "aos": "^2.3.4",
    "swiper": "^11.0.0"
  },
  "browserslist": [
    "defaults",
    "not IE 11",
    "not op_mini all"
  ],
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}
